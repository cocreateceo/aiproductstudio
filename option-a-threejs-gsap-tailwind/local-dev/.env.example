# AI Product Studio - Local Development Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# API KEYS (Required)
# =============================================================================
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# AWS CLI profile name (from ~/.aws/credentials)
AWS_PROFILE=cocreate

# AWS region for S3 and other services
AWS_REGION=us-east-1

# AWS region for SES (email service)
SES_REGION=us-east-1

# S3 bucket for storing applications
S3_BUCKET=cocreate-applications-data

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# HTTP Server port (Express)
PORT=5000

# WebSocket Server port (Worker)
WS_PORT=5001

# Worker polling interval in milliseconds
POLL_INTERVAL=10000

# =============================================================================
# SECURITY
# =============================================================================
# Admin portal password
ADMIN_PASSWORD=your-secure-password-here

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Email address for notifications
NOTIFICATION_EMAIL=your-email@example.com

# Set to true to skip sending emails (local development)
SKIP_EMAIL=true

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
# Claude model for MVP builder
CLAUDE_MODEL=claude-sonnet-4-20250514

# Max tokens for Claude responses
MAX_TOKENS=8192

# Command timeout in milliseconds
COMMAND_TIMEOUT=30000

# =============================================================================
# LOCAL DEVELOPMENT OPTIONS
# =============================================================================
# Enable local mode
LOCAL_MODE=true

# Enable debug logging
DEBUG=true
